# ── Database ─────────────────────────────────────────────────────────────────
# Use a MongoDB Atlas connection string for production
MONGO_URI=mongodb://localhost:27017/consultancy

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=2h

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS — comma-separated allowed frontend origins ─────────────────────────
# Example: https://greenkoolers.vercel.app
# Leave empty for open CORS in local development
FRONTEND_URL=
# Optional: comma-separated regex patterns for preview deployments
# Example: ^https://green-koolers(-[a-z0-9-]+)?\.vercel\.app$
FRONTEND_URL_REGEX=

# ── SMTP (outbound email notifications) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Green Koolers <your_email@gmail.com>"
ADMIN_EMAIL=admin@greenkoolers.com

# ── IMAP (inbound email reading — customer inbox) ───────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_email@gmail.com
IMAP_PASS=your_gmail_app_password
IMAP_MAILBOX=INBOX
# Optional IMAP timeout tuning (milliseconds)
IMAP_CONNECTION_TIMEOUT_MS=20000
IMAP_AUTH_TIMEOUT_MS=20000
IMAP_SOCKET_TIMEOUT_MS=180000
